# Saturn configuration. Copy this file to `.env` and fill in your values.
#
# config.ts loads the first `.env` it finds (the path in SATURN_ENV_FILE, then the current working
# directory, then the directory of the running bundle) and never overrides variables already set in the
# real environment, so explicit env vars always win.

# --- Repository to review (required) ---
# Simplest setup: the repo's URL (org/project/repo are parsed from it; no GUID needed) plus a branch.
SATURN_REPO_URL=https://dev.azure.com/your-organization/your-project/_git/your-repository
SATURN_ADO_DEFAULT_BRANCH=main

# Advanced alternative to SATURN_REPO_URL (these override the parsed URL when set):
# SATURN_ADO_HOST=dev.azure.com
# SATURN_ADO_ORG=your-organization
# SATURN_ADO_PROJECT=your-project
# SATURN_ADO_REPO_NAME=your-repository
# SATURN_ADO_REPO_ID=00000000-0000-0000-0000-000000000000   # optional; the repo name works without it

# --- Optional ---
# Copilot model. Use the best model your Copilot plan offers - treat it as your most senior engineer
# reviewing every PR. Defaults to claude-opus-4.8.
# SATURN_MODEL=claude-opus-4.8
# Enable the feedback page + per-comment feedback links (default off until signed-in attribution is wired up).
# SATURN_ENABLE_FEEDBACK=false
# Comma-separated PR author display names to skip (opt-out).
# SATURN_OPT_OUT_AUTHORS=Jane Doe,John Smith
# Public URL of the Saturn feedback page (defaults to the local dashboard at http://localhost:6789/feedback).
# SATURN_FEEDBACK_URL=https://saturn.example.com/feedback
# Identity allowed to start/stop the loop when hosted behind EasyAuth (defaults to your local git user.email).
# SATURN_OWNER=you@example.com

# --- Exposing the dashboard ---
# Owner control (Start/Stop) is automatically limited to direct requests from this machine; a request relayed
# through a reverse proxy or tunnel (e.g. devtunnel) is detected and treated as a non-owner viewer - no secret
# needed. When hosted behind Azure AD Easy Auth, the injected x-ms-client-principal-name identity is trusted
# instead; set SATURN_OWNER to your signed-in UPN.
